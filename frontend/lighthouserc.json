{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/queues",
        "http://localhost:4173/emergency"
      ],
      "numberOfRuns": 3,
      "startServerCommand": "cd frontend && npm run preview",
      "startServerReadyPattern": "Local",
      "startServerReadyTimeout": 15000
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.60 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.90 }],
        "categories:pwa": ["error", { "minScore": 0.85 }],
        "categories:seo": ["warn", { "minScore": 0.80 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
